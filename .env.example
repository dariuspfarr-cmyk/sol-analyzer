# SOL/USDT Analyzer — Konfiguration
# Kopiere diese Datei zu ".env" und passe die Werte bei Bedarf an.

# Handels-Konfiguration (optional, Standardwerte siehe unten)
SYMBOL=SOLUSDT
INTERVAL=4h
CANDLES=120

# WICHTIG: Niemals ANTHROPIC_API_KEY hier setzen!
